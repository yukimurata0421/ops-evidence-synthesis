# Cloud Build receives only files copied by gcp/cloudrun/Dockerfile.
# This allowlist keeps local analyses, raw inputs, workspaces, tests, and docs
# outside the uploaded build context.
**

!cloudbuild.yaml
!pyproject.toml
!README.md

!src/
!src/**
!scripts/
!scripts/**
!data/
!data/**
!gcp/
!gcp/**

**/__pycache__/**
**/*.pyc
**/*.egg-info/**
