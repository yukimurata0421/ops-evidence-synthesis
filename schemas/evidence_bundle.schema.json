{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Ops Evidence Synthesis evidence bundle",
  "type": "object",
  "required": [
    "schema_version",
    "evidence_sha256",
    "service",
    "environment",
    "window_start",
    "window_end",
    "query_sql_hash",
    "sanitizer_version",
    "evidence_refs",
    "logs",
    "log_patterns",
    "metric_windows"
  ],
  "properties": {
    "schema_version": { "const": "ops-evidence-bundle/v1" },
    "evidence_sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "service": { "type": "string" },
    "environment": { "type": "string" },
    "window_start": { "type": "string" },
    "window_end": { "type": "string" },
    "incident_window": {
      "type": "object",
      "required": ["start", "end"],
      "properties": {
        "start": { "type": "string" },
        "end": { "type": "string" }
      }
    },
    "lookback": { "type": "string" },
    "baseline": {
      "type": "object",
      "required": ["mode", "start", "end"],
      "properties": {
        "mode": { "type": "string" },
        "start": { "type": "string" },
        "end": { "type": "string" }
      }
    },
    "query_sql_hash": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "sanitizer_version": { "type": "string" },
    "evidence_refs": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": ["type", "summary"]
      }
    },
    "logs": { "type": "array" },
    "log_patterns": { "type": "array" },
    "metric_windows": { "type": "array" },
    "deployments": { "type": "array" },
    "similar_past_incidents": { "type": "array" }
  }
}
